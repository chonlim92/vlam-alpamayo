# ============================================
# VLAM-Alpamayo Configuration
# ============================================

# Hugging Face API Token
# Get your token at: https://huggingface.co/settings/tokens
#
# Required access (accept the license on each page):
#   Model weights (gated — request access, then accept license):
#     - Alpamayo 1:   https://huggingface.co/nvidia/Alpamayo-R1-10B
#     - Alpamayo 1.5: https://huggingface.co/nvidia/Alpamayo-1.5-10B
#   Datasets (gated — accept NVIDIA AV Dataset License Agreement):
#     - PhysicalAI-AV:      https://huggingface.co/datasets/nvidia/PhysicalAI-Autonomous-Vehicles
#     - PhysicalAI-AV-NuRec: https://huggingface.co/datasets/nvidia/PhysicalAI-Autonomous-Vehicles-NuRec
#   Public datasets (no approval needed — used via HF streaming):
#     - DriveLM, LingoQA, nuScenesQA, NAVSIM, Omnidrive,
#       Talk2Car, CODA-LM, DriveGPT4, Drive-Action, MapLM,
#       MM-AU, nuInstruct, Senna, Roadwork
#
# Token permissions needed: "Read" scope is sufficient.
HUGGINGFACE_API_TOKEN=<your-HF-Token>

# Model selection: "alpamayo-1" or "alpamayo-1.5"
DEFAULT_MODEL=alpamayo-1.5

# Device configuration
DEVICE=cuda
DTYPE=bfloat16

# Attention implementation: "flash_attention_2" or "sdpa"
ATTN_IMPLEMENTATION=sdpa

# Number of trajectory samples to generate
NUM_TRAJ_SAMPLES=1

# Output directory for results
OUTPUT_DIR=output

# GUI settings
GUI_HOST=127.0.0.1
GUI_PORT=7860
